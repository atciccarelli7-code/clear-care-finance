# Public preview laboratory. Keep false in production unless an internal preview is intentionally enabled.
VITE_ENABLE_PRIVATE_PRODUCT_LAB=false
VITE_ENABLE_PAID_PRODUCTS=false

# Canonical site URL used for secure cookie and magic-link destinations.
PUBLIC_SITE_URL=https://communityacquiredfinance.com

# Premium commerce remains default-deny unless every required server variable below is valid.
ENABLE_PREMIUM_COMMERCE=false

# Vercel Marketplace / Upstash Redis. Server only: never prefix these with VITE_.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV aliases are also accepted by the server functions.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Lemon Squeezy one-time product configuration. Server only.
LEMON_SQUEEZY_HEALTHCARE_PRODUCT_URL=
LEMON_SQUEEZY_HEALTHCARE_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Passwordless access delivery. RESEND_API_KEY should already exist for CAF email workflows.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Community Acquired Finance <access@communityacquiredfinance.com>
RESEND_NOTIFY_EMAIL=

# Optional future gated reference-PDF delivery. Use a short-lived signed private-storage URL,
# not a permanent public Drive or repository URL. Browser print-to-PDF works without this value.
PREMIUM_REFERENCE_PDF_URL=

# Existing hosted-checkout placeholders retained only for older private product-lab code.
# Do not expose active paid-product URLs through VITE_ variables in production.
VITE_LEMON_SQUEEZY_HEALTHCARE_PRODUCT_URL=
VITE_LEMON_SQUEEZY_MEDICAL_BILL_PRODUCT_URL=
VITE_LEMON_SQUEEZY_PRODUCT_BUNDLE_URL=
