# Healthcare Worker Benefits Decision System environment contract
# Never commit real values. Checkout and entitlement features default to disabled.

# -----------------------------------------------------------------------------
# Public application configuration (safe for browser use)
# -----------------------------------------------------------------------------
VITE_CANONICAL_APP_URL=https://communityacquiredfinance.com
VITE_PUBLIC_SUPABASE_URL=
VITE_PUBLIC_SUPABASE_ANON_KEY=
VITE_PREMIUM_AUTH_ENABLED=false
VITE_PREMIUM_EARLY_ACCESS_DISPLAY_ENABLED=true

# -----------------------------------------------------------------------------
# Server and build configuration
# Required in production for canonical redirects and controlled checkout URLs.
# -----------------------------------------------------------------------------
PUBLIC_APP_URL=https://communityacquiredfinance.com
PREMIUM_PUBLIC_PRODUCT_PAGE_ENABLED=true
PREMIUM_APPLICATION_SHELL_ENABLED=true
PREMIUM_AUTH_ENABLED=false
PREMIUM_WORKSPACE_PERSISTENCE_ENABLED=false
PREMIUM_ENTITLEMENTS_ENABLED=false
PREMIUM_CHECKOUT_ENABLED=false
PREMIUM_TEST_ADMIN_ENABLED=false
PREMIUM_PREVIEW_ACCESS_ENABLED=false
PREMIUM_PRODUCTION_CHECKOUT_AUTHORIZED=false

# -----------------------------------------------------------------------------
# Server-only Supabase configuration
# Required before authentication, entitlement checks, or workspace persistence.
# These variables MUST NEVER use a VITE_ prefix.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Server-only Stripe configuration
# Keep STRIPE_ENVIRONMENT=disabled and PREMIUM_CHECKOUT_ENABLED=false until the
# documented test-mode activation gates pass. Never use a VITE_ prefix.
# -----------------------------------------------------------------------------
STRIPE_ENVIRONMENT=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HEALTHCARE_WORKER_BENEFITS_DECISION_SYSTEM=

# -----------------------------------------------------------------------------
# Administrative and support configuration
# Values are comma-separated where more than one entry is allowed.
# Admin values are advisory release configuration; database admin access must
# also be explicitly provisioned in public.premium_admins through trusted tools.
# -----------------------------------------------------------------------------
PREMIUM_ADMIN_USER_IDS=
PREMIUM_ADMIN_EMAILS=
SUPPORT_EMAIL=support@communityacquiredfinance.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Community Acquired Finance <hello@communityacquiredfinance.com>
RESEND_NOTIFY_EMAIL=

# -----------------------------------------------------------------------------
# Optional local development only
# Vite development server only. The production build fails if this is true.
# This creates no account, payment, entitlement, or cloud-persistence authority.
# -----------------------------------------------------------------------------
VITE_PREMIUM_DEV_MOCK_AUTH=false
PREMIUM_MOCK_AUTH_ENABLED=false
PREMIUM_ENTITLEMENT_BYPASS=false
PREMIUM_CONTENT_SEED_STATUS=test
PREMIUM_CONTENT_SEED_PRODUCTION_AUTHORIZED=false
