# Private paid-product preview. Keep false in production until an internal preview is needed.
VITE_ENABLE_PRIVATE_PRODUCT_LAB=false

# Commerce master switch. This alone cannot activate checkout while catalog status remains private_ready.
VITE_ENABLE_PAID_PRODUCTS=false

# Hosted Lemon Squeezy checkout URLs. Leave empty until merchant approval and test purchases are complete.
VITE_LEMON_SQUEEZY_HEALTHCARE_PRODUCT_URL=
VITE_LEMON_SQUEEZY_MEDICAL_BILL_PRODUCT_URL=
VITE_LEMON_SQUEEZY_PRODUCT_BUNDLE_URL=
