{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://communityacquiredfinance.com/patient-education/schemas/controlled-preview-bundle-v1.schema.json",
  "title": "CAF Patient Education Controlled Preview Bundle",
  "description": "Public-safe release metadata for a controlled preview. The bundle contains no deployable clinical instructions, evidence dossiers, reviewer identity records, PHI-capable fields, hospital customizations, contracts, or pricing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "generatedAt",
    "mode",
    "packageDescriptor",
    "artifactIndex",
    "withheldCategories",
    "claimsBoundary"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "bundleId": { "type": "string", "pattern": "^CAF-PE-[A-Z0-9-]+-v\\d+\\.\\d+\\.\\d+-controlled_preview$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "const": "controlled_preview" },
    "packageDescriptor": { "$ref": "./public-package-descriptor-v1.schema.json" },
    "artifactIndex": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetId", "target", "path", "mimeType", "checksum", "version"],
        "properties": {
          "assetId": { "type": "string", "pattern": "^CAF-PE-[A-Z0-9-]+$" },
          "target": { "enum": ["responsive_html", "print_html", "structured_text", "avs_text", "patient_portal_json"] },
          "path": { "type": "string", "pattern": "^[a-z0-9/_\\.-]+$" },
          "mimeType": { "type": "string", "minLength": 3 },
          "checksum": { "type": "string", "pattern": "^fnv1a-[a-f0-9]{8}$" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
        }
      }
    },
    "withheldCategories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "restricted_clinical_instruction_assets",
          "patient_specific_fields",
          "phi_capable_fields",
          "evidence_dossiers",
          "reviewer_identity_records",
          "hospital_customizations",
          "contracts_and_pricing",
          "client_deliverables"
        ]
      }
    },
    "claimsBoundary": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 10 } }
  }
}
